{
  "welcomeFile": "/webapp/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/odata/v4/incident/(.*)$",
      "target": "/odata/v4/incident/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/webapp/(.*)$",
      "target": "$1",
      "localDir": "webapp",
      "authenticationType": "xsuaa"
    }
  ]
}
