{
  "_version": "1.40.0",
  "sap.app": {
    "id": "itsm.ui",
    "type": "application",
    "title": "ITSM - New Incident",
    "dataSources": {
      "incidentService": {
        "uri": "/odata/v4/incident/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "itsm.ui.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "itsm.ui.i18n.i18n" }
      },
      "": {
        "dataSource": "incidentService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true,
          "groupId": "$auto",
          "updateGroupId": "incidentGroup"
        }
      }
    },
    "resources": {
      "css": [{ "uri": "css/style.css" }]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "itsm.ui.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        { "pattern": "", "name": "main", "target": "main" }
      ],
      "targets": {
        "main": { "viewName": "Main", "viewId": "main" }
      }
    }
  }
}
