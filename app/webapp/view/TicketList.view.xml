<mvc:View
  controllerName="itsm.ui.controller.TicketList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="listPage" showHeader="false" backgroundDesign="Transparent" class="appBg">

    <!-- breadcrumb + search -->
    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
      <Breadcrumbs currentLocationText="Incidents">
        <Link text="Vantara Industries"/>
      </Breadcrumbs>
      <HBox alignItems="Center">
        <SearchField placeholder="Search Tickets, Assets,..." width="260px"/>
        <Button icon="sap-icon://menu2" type="Transparent"/>
      </HBox>
    </HBox>

    <!-- header -->
    <VBox class="headerCard">
      <HBox justifyContent="SpaceBetween" alignItems="Center">
        <VBox>
          <Text text="Tickets" class="headerTitle"/>
          <Text text="All Service Request Records" class="headerSub"/>
        </VBox>
        <HBox>
          <Button text="Create New Ticket" icon="sap-icon://add" class="submitBtn" press=".onCreateTicket"/>
        </HBox>
      </HBox>
    </VBox>

    <VBox class="sectionCard">
      <Table
        id="ticketTable"
        inset="false"
        growing="true"
        growingThreshold="50"
        items="{
          path: '/Incident',
          parameters: {
            $expand: 'status($select=name),priority($select=name),category1($select=name)',
            $orderby: 'createdAt desc'
          }
        }"
        noDataText="No tickets yet. Click 'Create New Ticket' to add one.">

        <headerToolbar>
          <OverflowToolbar>
            <Title text="Incidents ({= ${ticketTable>/}.length })" level="H4"/>
            <ToolbarSpacer/>
            <SearchField
              width="18rem"
              placeholder="Search incident # or description"
              search=".onSearch"
              liveChange=".onSearch"/>
          </OverflowToolbar>
        </headerToolbar>

        <columns>
          <Column><Text text="Incident #"/></Column>
          <Column><Text text="Short Description"/></Column>
          <Column><Text text="Status"/></Column>
          <Column><Text text="Priority"/></Column>
          <Column><Text text="Category"/></Column>
          <Column><Text text="Assigned To"/></Column>
          <Column><Text text="Created By"/></Column>
          <Column><Text text="Created On"/></Column>
          <Column><Text text="Last Updated"/></Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation" press=".onTicketPress">
            <cells>
              <ObjectIdentifier title="{incidentNumber}"/>
              <Text text="{shortDescription}"/>
              <Text text="{status/name}"/>
              <Text text="{priority/name}"/>
              <Text text="{category1/name}"/>
              <Text text="{messageProcessor}"/>
              <Text text="{createdBy}"/>
              <Text text="{ path: 'createdAt', formatter: '.formatDateTime' }"/>
              <Text text="{ path: 'modifiedAt', formatter: '.formatDateTime' }"/>
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </VBox>

  </Page>
</mvc:View>
